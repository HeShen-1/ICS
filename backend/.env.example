# === 必填 ===
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# === MySQL ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ics_user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=ics_customer_service

# === LLM ===
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=30
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=3

# === Embedding ===
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# === Milvus ===
MILVUS_DB_PATH=./data/milvus/ics_knowledge.db

# === JWT ===
# 至少 32 字符。生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-string-32chars+
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === 业务参数 ===
TOP_K=12
SIMILARITY_THRESHOLD=0.55
MAX_QUESTION_LENGTH=500
DAILY_QUESTION_LIMIT=100
MAX_HISTORY_ROUNDS=5
MAX_CONTEXT_TOKENS=8000
MAX_UPLOAD_SIZE=10485760
FALLBACK_THRESHOLD=0.35

# === Security ===
PROMPT_INJECTION_ENABLED=true

# === 文件 ===
UPLOAD_DIR=./data/uploads

# === RAGAS 自动评估（可选，需要 LLM API Key） ===
RAGAS_LLM_MODEL=deepseek-chat
EVAL_RETRIEVAL_TOP_K=12
EVAL_SIMILARITY_THRESHOLD=0.55

# === 系统用户（可选，用于初始化示例知识库） ===
# 不设置则自动生成随机密码
# SYSTEM_USER_PASSWORD=
